<html lang="en">
<head>
<meta charset="UTF-8"></meta>
<meta content="width=device-width, initial-scale=1.0" name="viewport"></meta>
<title>Age Calculator - Free Online Age Calculator</title>
<meta content="Free SEO-friendly Age Calculator. Calculate your exact age in years, months, and days instantly." name="description"></meta>
<meta content="age calculator, online age calculator, calculate age, birthday calculator" name="keywords"></meta>
<meta content="index, follow" name="robots"></meta>
<style>
body{font-family:Arial,sans-serif;background:#f4f7fb;margin:0;padding:20px}

h1{text-align:center}
input,button{width:100%;padding:12px;margin:10px 0;border:1px solid #ccc;border-radius:6px}
button{background:#2563eb;color:#fff;border:none;cursor:pointer}
button:hover{background:#1d4ed8}
.result{margin-top:20px;padding:15px;background:#0f1933;border-radius:6px;font-size:18px}
  
  h1,
h2,
h3{
color:#f39808 !important;
  line-height: 1.5;
}
  
</style>
<script type="application/ld+json">
{
 "@context":"https://schema.org",
 "@type":"WebApplication",
 "name":"Age Calculator",
 "applicationCategory":"UtilityApplication",
 "description":"Calculate exact age from date of birth."
}
</script>
</head>
<body>
<div class="container">
<h1>Age Calculator</h1>
<p>Enter your date of birth to calculate your exact age.</p>
<br />
  <label for="dob"><strong>Date of Birth</strong></label>
<input id="dob" type="date" />

<button onclick="calculateAge()">Calculate Age</button>

<div class="result" id="result" style="display: none;"></div>

  <br />
    <br />
    <br />
    <br />
    <br />
    <br />
<h2>About This Age Calculator</h2>
<p>This free online Age calculator helps you calculate your exact Age in years, months, and days. It works instantly .</p>
</div>

<script>
function calculateAge() {
    const dob = new Date(document.getElementById('dob').value);
    const result = document.getElementById('result');

    if (!document.getElementById('dob').value) {
        result.style.display = 'block';
        result.innerHTML = 'Please select your date of birth.';
        return;
    }

    const today = new Date();

    let years = today.getFullYear() - dob.getFullYear();
    let months = today.getMonth() - dob.getMonth();
    let days = today.getDate() - dob.getDate();

    if (days < 0) {
        months--;
        const prevMonth = new Date(today.getFullYear(), today.getMonth(), 0);
        days += prevMonth.getDate();
    }
if (months < 0) {
        years--;
        months += 12;
    }

    result.style.display = 'block';
    result.innerHTML = `<strong>Your Age:</strong> ${years} Years, ${months} Months, ${days} Days`;
}
</script>
</body>
</html>
